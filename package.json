{
  "name": "signaltrim",
  "version": "0.6.4",
  "description": "SignalTrim installer detects AI coding agents and installs compact technical reply mode for each one.",
  "license": "MIT",
  "author": "SignalTrim contributors",
  "homepage": "https://github.com/karurikwao/signaltrim",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karurikwao/signaltrim.git"
  },
  "bugs": {
    "url": "https://github.com/karurikwao/signaltrim/issues"
  },
  "bin": {
    "signaltrim": "./bin/install.js",
    "signaltrim-shrink": "./src/mcp-servers/signaltrim-shrink/index.js"
  },
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "test": "node --test tests/installer/*.test.mjs",
    "smoke": "node --test tests/smoke/*.test.mjs",
    "test:standalone": "node scripts/run-standalone-js-tests.cjs",
    "test:python": "python -m unittest discover -s tests -p \"test_*.py\"",
    "verify": "python tests/verify_repo.py",
    "check:install-surfaces": "node scripts/check-install-surfaces.cjs",
    "pack:dry": "npm pack --dry-run --json"
  },
  "files": [
    "bin/",
    "src/",
    "agents/",
    "skills/",
    "plugins/",
    "commands/",
    "benchmarks/",
    "evals/",
    "CLAUDE.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "INSTALL.md",
    "SECURITY.md",
    "docs/",
    "dist/signaltrim.skill",
    "README.md",
    "LICENSE",
    "!**/__pycache__/**",
    "!**/*.pyc"
  ]
}
